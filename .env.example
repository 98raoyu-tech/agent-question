# =============================================================================
# 企业级 AI 工作流操作系统 - 环境变量模板
# 使用方式：复制本文件为 .env 并填写实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 数据库配置 (PostgreSQL + pgvector 向量扩展)
# 用途：主业务数据存储 + 向量检索（Agent 记忆、文档 Embedding 等）
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_workflow_os

# -----------------------------------------------------------------------------
# Redis 配置
# 用途：会话缓存、分布式锁、限流计数器、消息队列
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Neo4j 图数据库配置
# 用途：存储 Agent 关系图谱、工作流 DAG、知识图谱
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# -----------------------------------------------------------------------------
# Kafka 消息队列配置
# 用途：事件总线、异步任务分发、Agent 间通信、审计日志流
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# -----------------------------------------------------------------------------
# Temporal 工作流引擎配置
# 用途：持久化工作流编排、任务调度、重试与超时管理
# -----------------------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233

# -----------------------------------------------------------------------------
# JWT 认证配置
# 用途：API 鉴权、用户身份校验、Token 签发与验证
# 注意：生产环境务必使用高强度随机密钥，切勿使用默认值
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# -----------------------------------------------------------------------------
# 飞书 OAuth2 配置
# 用途：飞书登录、统一认证中心
# 获取方式：飞书开放平台 -> 创建应用 -> 获取 App ID 和 App Secret
# 文档：https://open.feishu.cn/document/common-capabilities/sso/api/get-access_token
# -----------------------------------------------------------------------------
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_REDIRECT_URI=http://localhost:9000/api/v1/auth/callback

# -----------------------------------------------------------------------------
# 前端地址配置
# 用途：飞书登录回调后重定向地址
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Langfuse 可观测性配置
# 用途：LLM 调用追踪、Prompt 管理、成本监控、质量评估
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxx

# -----------------------------------------------------------------------------
# OpenAI API 配置
# 用途：大语言模型调用（GPT-4、Embedding 等）
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxx

# -----------------------------------------------------------------------------
# 日志级别配置
# 可选值：DEBUG | INFO | WARNING | ERROR | CRITICAL
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
